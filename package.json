{
  "name": "rtc-workspace-monorepo",
  "version": "1.0.0",
  "description": "Unified orchestration workspace for real-time app",
  "private": true,
  "scripts": {
    "backend": "npm start --prefix rtc-backend",
    "frontend": "npm run dev --prefix rtc-frontend",
    "start": "concurrently --kill-others-on-fail \"npm run backend\" \"npm run frontend\""
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "livekit-client": "^2.20.1",
    "livekit-server-sdk": "^2.17.0"
  }
}
